<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:keepScreenOn="true">

    <!-- Video Player -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/bg_primary"
        app:controller_layout_id="@layout/exo_player_control_view"
        app:hide_on_touch="true"
        app:layout_constraintBottom_toTopOf="@id/controlsContainer"
        app:layout_constraintEnd_toStartOf="@id/playlistContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:resize_mode="fit"
        app:show_buffering="when_playing"
        app:use_controller="true" />

    <!-- Controls Container -->
    <LinearLayout
        android:id="@+id/controlsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/bg_control_bar"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/playlistContainer"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Seek Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="90dp"
                android:text="00:00 / 00:00"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="1000"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent" />

            <TextView
                android:id="@+id/tvVolume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="45dp"
                android:text="80%"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Volume Slider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊"
                android:textSize="14sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/volumeSlider"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:stepSize="0.05"
                android:value="0.8"
                android:valueFrom="0"
                android:valueTo="1"
                app:thumbColor="@color/accent"
                app:trackColorActive="@color/accent"
                app:trackColorInactive="@color/bg_surface" />
        </LinearLayout>

        <!-- Control Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPrev"
                style="@style/ControlButton"
                android:text="⏮" />

            <Button
                android:id="@+id/btnPlayPause"
                style="@style/ControlButton.Accent"
                android:text="▶" />

            <Button
                android:id="@+id/btnStop"
                style="@style/ControlButton"
                android:text="⏹" />

            <Button
                android:id="@+id/btnNext"
                style="@style/ControlButton"
                android:text="⏭" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="8dp"
                android:background="@color/border" />

            <Button
                android:id="@+id/btnOpen"
                style="@style/ControlButton"
                android:text="📂" />

            <Button
                android:id="@+id/btnPlaylist"
                style="@style/ControlButton"
                android:text="📋" />

            <Button
                android:id="@+id/btnFullscreen"
                style="@style/ControlButton"
                android:text="⛶" />
        </LinearLayout>
    </LinearLayout>

    <!-- Playlist Sidebar -->
    <LinearLayout
        android:id="@+id/playlistContainer"
        android:layout_width="280dp"
        android:layout_height="0dp"
        android:background="@color/bg_secondary"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Playlist Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@color/bg_surface"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📋 Playlist"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPlaylistCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 files"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playlistRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="4dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
